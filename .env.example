# ─── SUMIT credentials ───────────────────────────────────────────
# לוח הבקרה של סאמיט ← הגדרות ← API
# העתק קובץ זה ל-.env.local ומלא ערכים אמיתיים.

# מזהה החברה — לא סודי. נשלף ללקוח דרך /api/sumit/config
COMPANY_ID=

# מפתח Public לטוקניזציה — לא סודי. נשלף ללקוח דרך /api/sumit/config
SUMIT_PUBLIC_KEY=

# מפתח Private — צד שרת בלבד (charge/route.js). אל תחשוף ואל תעלה ל-git!
SUMIT_PRIVATE_KEY=
