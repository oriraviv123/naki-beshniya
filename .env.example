# ─── SUMIT credentials ───────────────────────────────────────────
# לוח הבקרה של סאמיט ← הגדרות ← API
# העתק קובץ זה ל-.env.local ומלא ערכים אמיתיים.

# ציבורי — מוזרק ל-frontend (PaymentForm.jsx)
NEXT_PUBLIC_SUMIT_COMPANY_ID=
NEXT_PUBLIC_SUMIT_API_PUBLIC_KEY=

# פרטי — צד שרת בלבד (route.js). אל תחשוף ואל תעלה ל-git!
SUMIT_COMPANY_ID=
SUMIT_API_KEY=
